generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  username        String           @unique
  password        String
  role            Role             @default(USER)
  avatar          String?
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  name            String?
  title           String?
  activityLogs    ActivityLog[]
  comments        Comment[]
  conversations   Conversation[]
  files           File[]
  findingStatuses FindingStatus[]
  knowledgeBases  KnowledgeBase[]
  knowledgeFiles  KnowledgeFile[]  @relation("UserKnowledgeFiles")
  assignedTasks   TaskAssignment[] @relation("TaskAssignee")
  createdTasks    TaskAssignment[] @relation("TaskCreator")
  settings        UserSetting[]
  workspaces      Workspace[]

  @@map("users")
}

model Conversation {
  id        String    @id @default(cuid())
  title     String
  userId    String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  memories  Memory[]
  messages  Message[]

  @@index([userId])
  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String
  metadata       Json?
  tokenCount     Int?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("messages")
}

model Memory {
  id             String        @id @default(cuid())
  conversationId String?
  type           MemoryType
  content        String
  embedding      Float[]
  metadata       Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  conversation   Conversation? @relation(fields: [conversationId], references: [id])

  @@index([conversationId])
  @@index([type])
  @@map("memories")
}

model File {
  id           String     @id @default(cuid())
  userId       String
  filename     String
  originalName String
  mimeType     String
  size         Int
  storagePath  String
  status       FileStatus @default(PENDING)
  metadata     Json?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("files")
}

model KnowledgeBase {
  id          String              @id @default(cuid())
  userId      String
  name        String
  description String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents   KnowledgeDocument[]

  @@index([userId])
  @@map("knowledge_bases")
}

model KnowledgeDocument {
  id              String        @id @default(cuid())
  knowledgeBaseId String
  title           String
  content         String
  sourceUrl       String?
  embedding       Float[]
  metadata        Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  knowledgeBase   KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)

  @@index([knowledgeBaseId])
  @@map("knowledge_documents")
}

model UserSetting {
  id        String   @id @default(cuid())
  userId    String
  key       String
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId])
  @@map("user_settings")
}

model SystemConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("system_configs")
}

model KnowledgeFile {
  id           String           @id @default(cuid())
  filename     String
  originalName String
  mimeType     String
  size         Int
  storagePath  String
  status       FileStatus       @default(PENDING)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  userId       String?
  chunks       KnowledgeChunk[]
  user         User?            @relation("UserKnowledgeFiles", fields: [userId], references: [id], onDelete: Cascade)

  @@map("knowledge_files")
}

model KnowledgeChunk {
  id              String        @id @default(cuid())
  knowledgeFileId String
  chunkIndex      Int
  content         String
  createdAt       DateTime      @default(now())
  knowledgeFile   KnowledgeFile @relation(fields: [knowledgeFileId], references: [id], onDelete: Cascade)

  @@index([knowledgeFileId])
  @@map("knowledge_chunks")
}

model AnalysisReportCache {
  id                 String           @id @default(cuid())
  fileName           String
  fileSize           Int
  projectName        String?
  projectType        String
  languages          String[]
  healthScore        Int
  securityScore      Int?
  codeQualityScore   Int?
  technicalDebtScore Int?
  analysisType       String           @default("FULL_ANALYSIS")
  summary            String?
  results            Json
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  lastAnalyzedAt     DateTime?
  workspaceName      String?
  workspacePath      String?
  isShared           Boolean          @default(true)
  ownerId            String?
  activityLogs       ActivityLog[]
  comments           Comment[]
  findingStatuses    FindingStatus[]
  tasks              TaskAssignment[]

  @@index([ownerId])
  @@index([isShared])
  @@map("analysis_report_caches")
}

model Comment {
  id         String              @id @default(cuid())
  reportId   String
  userId     String
  content    String
  filePath   String?
  lineNumber Int?
  findingId  String?
  parentId   String?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  parent     Comment?            @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies    Comment[]           @relation("CommentReplies")
  report     AnalysisReportCache @relation(fields: [reportId], references: [id], onDelete: Cascade)
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([userId])
  @@index([parentId])
  @@map("comments")
}

model TaskAssignment {
  id          String              @id @default(cuid())
  reportId    String
  findingId   String?
  filePath    String?
  title       String
  description String?
  assigneeId  String?
  creatorId   String
  status      TaskStatus          @default(OPEN)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  assignee    User?               @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creator     User                @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  report      AnalysisReportCache @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([assigneeId])
  @@index([creatorId])
  @@map("task_assignments")
}

model FindingStatus {
  id          String              @id @default(cuid())
  reportId    String
  findingId   String
  status      FindingStatusVal    @default(OPEN)
  notes       String?
  updatedById String
  updatedAt   DateTime            @updatedAt
  report      AnalysisReportCache @relation(fields: [reportId], references: [id], onDelete: Cascade)
  updatedBy   User                @relation(fields: [updatedById], references: [id], onDelete: Cascade)

  @@unique([reportId, findingId])
  @@index([reportId])
  @@map("finding_statuses")
}

model ActivityLog {
  id        String              @id @default(cuid())
  reportId  String
  userId    String
  type      ActivityLogType
  details   Json
  createdAt DateTime            @default(now())
  report    AnalysisReportCache @relation(fields: [reportId], references: [id], onDelete: Cascade)
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([userId])
  @@map("activity_logs")
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum MemoryType {
  SHORT_TERM
  LONG_TERM
  EPISODIC
  SEMANTIC
}

enum FileStatus {
  PENDING
  PROCESSING
  READY
  ERROR
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  IGNORED
}

enum FindingStatusVal {
  OPEN
  IN_PROGRESS
  RESOLVED
  FALSE_POSITIVE
  IGNORED
}

enum ActivityLogType {
  COMMENT_ADDED
  COMMENT_DELETED
  TASK_ASSIGNED
  TASK_STATUS_CHANGED
  RESOLUTION_CHANGED
  REPORT_SHARED
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  path      String   @unique
  userId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("workspaces")
}

